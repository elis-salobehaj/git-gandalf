# Test environment — fake credentials only, safe to commit.
# Bun auto-loads this file when NODE_ENV=test (set automatically by `bun test`).
# This allows src/config.ts to evaluate process.env at module load time without
# throwing, because all required fields are present before any import runs.

# GitLab
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=glpat-test-token
GITLAB_WEBHOOK_SECRET=test-webhook-secret

# AWS Bedrock (not called in Phase 1 tests, but required by the config schema)
AWS_REGION=us-west-2
AWS_BEARER_TOKEN_BEDROCK=test-bearer-token
AWS_AUTH_SCHEME_PREFERENCE='smithy.api#httpBearerAuth'

# LLM
LLM_MODEL=global.anthropic.claude-sonnet-4-6
LLM_PROVIDER_ORDER=bedrock
MAX_TOOL_ITERATIONS=15
MAX_SEARCH_RESULTS=100

# Service
REPO_CACHE_DIR=/tmp/git-gandalf-test-cache
LOG_LEVEL=info
PORT=8020

# Task queue (Phase 5.1) — disabled in tests; no Valkey required
QUEUE_ENABLED=false
VALKEY_URL=redis://localhost:6379
WORKER_CONCURRENCY=2
REVIEW_JOB_TIMEOUT_MS=600000
