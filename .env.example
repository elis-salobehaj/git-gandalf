# GitLab
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=glpat-xxxxx
GITLAB_WEBHOOK_SECRET=your-webhook-secret

# AWS Bedrock (bearer token auth)
AWS_REGION=us-west-2
AWS_BEARER_TOKEN_BEDROCK=<your-bedrock-bearer-token>
AWS_AUTH_SCHEME_PREFERENCE='smithy.api#httpBearerAuth'

# LLM
LLM_MODEL=global.anthropic.claude-sonnet-4-6
MAX_TOOL_ITERATIONS=15
MAX_SEARCH_RESULTS=100

# Service
REPO_CACHE_DIR=/tmp/repo_cache
LOG_LEVEL=info
PORT=8020

# Jira read-only context enrichment (Phase 4.5)
# Set JIRA_ENABLED=true to activate ticket-context fetching.
# Integration is disabled by default — existing setups are unaffected.
JIRA_ENABLED=false
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=<jira-api-token>
# Optional: comma-separated project key allow-list (e.g. ENG,PLATFORM).
# When unset, all extracted ticket keys are fetched.
# JIRA_PROJECT_KEYS=ENG,PLATFORM
# Optional: custom-field ID for acceptance criteria (e.g. customfield_12345).
# JIRA_ACCEPTANCE_CRITERIA_FIELD_ID=customfield_12345
# Optional: tuning knobs (shown with their defaults)
# JIRA_MAX_TICKETS=5
# JIRA_TICKET_TIMEOUT_MS=5000

# GitLab deployment hardening (Phase 4.6)
# Set GITLAB_CA_FILE when your self-hosted GitLab uses an internal / enterprise CA.
# Provide the absolute path to a PEM-encoded CA bundle.
# GitGandalf will set GIT_SSL_CAINFO for git subprocesses and NODE_EXTRA_CA_CERTS
# for the @gitbeaker/rest API client so TLS verification succeeds.
# Leave unset for GitLab.com and self-hosted instances with a publicly trusted cert.
# GITLAB_CA_FILE=/etc/ssl/certs/your-internal-ca.pem
